#include <windows.h>
#include <winver.h>

#define IDI_APP_ICON 101


VS_VERSION_INFO VERSIONINFO
 FILEVERSION 3,3,0,0
 PRODUCTVERSION 3,3,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0" // Language: US English, Codepage: Unicode
        BEGIN
            VALUE "CompanyName", "Daniel McGuire"
            VALUE "FileDescription", "Native port of Dino Game"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "dino_game.exe"
            VALUE "LegalCopyright", "(C) 2026 Daniel McGuire"
            VALUE "OriginalFilename", "DinoGame.exe"
            VALUE "ProductName", "Chromium Dino Game"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

IDI_APP_ICON ICON "..\\assets\\dino_game.ico"

